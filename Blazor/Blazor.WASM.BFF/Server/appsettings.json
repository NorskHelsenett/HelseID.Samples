{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "adminapi": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/SampleApi/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "User"
        }
      }
    },

    "Clusters": {
      "cluster1": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5081/user-login-clients/greetings"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
