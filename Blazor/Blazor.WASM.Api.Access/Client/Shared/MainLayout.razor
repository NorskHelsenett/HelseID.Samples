@inherits LayoutComponentBase
<RadzenLayout class="rz-shadow-3">
    <RadzenHeader>
        <div class="rz-display-flex rz-row rz-align-items-center rz-justify-content-flex-start">
            <div class="rz-col5">
                <div class="rz-display-flex rz-row rz-align-items-center rz-justify-content-flex-start">
                    <RadzenSidebarToggle Click="@(() => sidebar1Expanded = !sidebar1Expanded)" />
                    <RadzenLabel class="h3" Text="HelseId Admin" />
                </div>
            </div>
            <div class="rz-col7">
                <div class="rz-stack rz-display-flex rz-flex-row rz-align-items-center rz-justify-content-flex-end">
                    <LoginDisplay />
                </div>
            </div>
        </div>
    </RadzenHeader>
    <RadzenSidebar @bind-Expanded="@sidebar1Expanded">
       <SideBar />
    </RadzenSidebar>
    <RadzenBody>
        <div class="p-2">
            @Body
        </div>
    </RadzenBody>
    <RadzenFooter>
        <Footer />
    </RadzenFooter>
</RadzenLayout>

@code {
    bool sidebar1Expanded = true;

}

